# PostgreSQL (GORM DSN)
POSTGRES_DSN=host=localhost user=aayush password= dbname=gopherflow port=5432 sslmode=disable

# Redis
REDIS_ADDR=localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_EXECUTE_TOPIC=execute-stage
KAFKA_RESPONSE_TOPIC=execution-response

# WorkflowOrchestrator HTTP
HTTP_PORT=8080

# Max concurrent background tasks per service (workflow init, stage dispatch, execution)
WORKER_POOL_SIZE=16

# Observability (separate ports; do NOT use 9092 — that is KAFKA_BROKERS)
ORCHESTRATOR_METRICS_PORT=9091
EVENT_HANDLER_METRICS_PORT=9094
METRICS_PORT=9091
LOG_LEVEL=info
LOG_FORMAT=json
KAFKA_DLQ_TOPIC=stage-dlq

# Timeouts (seconds) — prevent hung goroutines
SHUTDOWN_TIMEOUT_SEC=15
KAFKA_READ_TIMEOUT_SEC=5
REDIS_TIMEOUT_SEC=3
DB_TIMEOUT_SEC=10

# Event_Handler — Ollama LLM endpoint
OLLAMA_URL=http://localhost:11434/api/generate

# SMTP — notify on stage failure after retries exhausted
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=gopherflow@example.com
SMTP_TO=you@example.com
